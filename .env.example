# ── Required ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ── Storage ───────────────────────────────────────────────────────────────────
# Temporary directory for downloaded videos (auto-created per user)
DOWNLOAD_DIR=/tmp/tiktok_downloads

# ── Workers ───────────────────────────────────────────────────────────────────
# Number of videos that can be downloaded in parallel across all users
MAX_WORKERS=3

# ── File size ─────────────────────────────────────────────────────────────────
# Telegram bot API limit is 50 MB. Keep at 45 MB to leave headroom.
# Videos larger than this are automatically split into parts with FFmpeg.
MAX_FILE_SIZE_MB=45

# ── Session TTL ───────────────────────────────────────────────────────────────
# Seconds before a pending quality-selection session expires (default 5 min)
SESSION_TTL=300

# ── FFmpeg paths ──────────────────────────────────────────────────────────────
# Docker / Linux server: leave as "ffmpeg" and "ffprobe" (uses system PATH)
# Windows local dev: point to your local executables in assets/
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# FFMPEG_PATH=assets/ffmpeg.exe
# FFPROBE_PATH=assets/ffprobe.exe

# ── Optional: TikTok cookies ──────────────────────────────────────────────────
# Export cookies from your browser using a cookie-export extension.
# Save as assets/cookies.txt (Netscape format) and uncomment below.
# COOKIES_FILE=assets/cookies.txt

# ── Optional: MongoDB Atlas (required on Render free tier) ────────────────────
# If set, user data is stored in MongoDB instead of a local JSON file.
# Free 512 MB cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
# MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net
